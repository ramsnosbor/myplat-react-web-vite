# ─── DESENVOLVIMENTO (.env.local) ───────────────────────────────────────────
# Em dev, usar paths de proxy para evitar CORS:
#   VITE_API_URL=/proxy/api
#   VITE_SSO_URL=/proxy/sso
#   VITE_NFE_URL=/proxy/nfe
#
# Targets do proxy Vite (sem VITE_ — server-side only, não vai no bundle):
#   PROXY_SSO_TARGET=https://apisso.myplat.com.br
#   PROXY_API_TARGET=https://api.myplat.net.br
#   PROXY_NFE_TARGET=https://apinfe.myplat.net.br

# ─── PRODUÇÃO (.env.production) ─────────────────────────────────────────────
# Em prod, usar URLs diretas (CORS configurado no servidor):
VITE_API_URL=https://api.myplat.net.br/pfs
VITE_SSO_URL=https://apisso.myplat.net.br/sso
VITE_NFE_URL=https://apinfe.myplat.net.br/nfe

# URL do Maker
VITE_MAKER_URL=https://maker.myplat.net.br

# Cookie
VITE_COOKIE_DOMAIN=.myplat.net.br
VITE_COOKIE_EXPIRATION_DAYS=7

# Notificações / Toasts
VITE_NOTIFICATION_DURATION=5000
VITE_TOAST_DURATION=3000
VITE_NOTIFICATION_ICON_PATH=/assets/icons
